# Server Port
PORT=xxxxx
RUN_BACKGROUND_JOBS=false

# Redis
REDIS_URL=rediss://your-managed-redis-url
# Optional only for local non-URL Redis setups:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Database
DATABASE_URL=mongodb+srv://xxxxxxxx:xxxxxxxxxxxxxxxxxxx@codiecluster.nezlvor.mongodb.net/codie?retryWrites=true&w=majority&appName=codieCluster

# JWT Secrets
ACCESS_TOKEN_SECRET=youraccesstokensecret
REFRESH_TOKEN_SECRET=yourrefreshtokensecret

# Email
EMAIL_USER=xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_PASS=xxxxxxxxxxxxx

# Frontend Client URL (must match the browser origin exactly)
CLIENT_URL=https://your-frontend.vercel.app

# Optional: extra CORS origins (comma-separated)
# CORS_ORIGINS=https://your-custom-domain.com,http://localhost:3000

# Gemini api key
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
 
# Cloudinary
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
CLOUDINARY_CLOUD_NAME=xxxxxxxxxxxxxxxxxxxxxx
CLOUDINARY_SECRET=xxxxxxxxxxxxxxxxxxx

# Razorpay
RAZORPAY_KEY_ID=xxxxxxxxxxxxxx
RAZORPAY_SECRET_ID=xxxxxxxxxxxxxxxx

GRAPHQL_API= https://studio.apollographql.com

